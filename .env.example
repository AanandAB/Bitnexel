# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# ============================================
# API CONFIGURATION
# ============================================
# Base URL for backend API (if you add one)
VITE_API_URL=

# ============================================
# EMAIL SERVICE (EmailJS)
# ============================================
# Get these from https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ============================================
# ANALYTICS
# ============================================
# Google Analytics 4 Tracking ID
# Get from https://analytics.google.com/
VITE_GA_TRACKING_ID=

# Plausible Analytics Domain (privacy-focused alternative)
# Get from https://plausible.io/
VITE_PLAUSIBLE_DOMAIN=

# ============================================
# SALESFORCE INTEGRATION (if re-enabling)
# ============================================
# Salesforce OAuth credentials
VITE_SALESFORCE_CONSUMER_KEY=
VITE_SALESFORCE_CONSUMER_SECRET=
VITE_SALESFORCE_INSTANCE_URL=

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_LIVE_CHAT=false
VITE_ENABLE_NEWSLETTER=false

# ============================================
# THIRD-PARTY SERVICES
# ============================================
# Google Maps API (if adding location features)
VITE_GOOGLE_MAPS_API_KEY=

# Stripe (if adding payments)
VITE_STRIPE_PUBLISHABLE_KEY=

# Sentry (error tracking)
VITE_SENTRY_DSN=

# ============================================
# DEVELOPMENT
# ============================================
# Set to 'development' or 'production'
VITE_APP_ENV=development
